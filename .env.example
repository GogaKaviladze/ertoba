# Prisma / Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Supabase (public keys)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase Service Role Key (server-side only – never expose to the client)
# Required for Personal (Zero-Knowledge) account creation without email confirmation.
# Find it in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Field-level encryption key for SurveyCompletion.results (32 bytes = 64 hex chars)
# Generate a new key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ASSESSMENT_ENCRYPTION_KEY="your-64-char-hex-encryption-key"

# GitHub (for agent automation)
GITHUB_API="ghp_your-github-personal-access-token"
REPO_LINK="https://github.com/your-username/your-repo"
